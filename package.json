{
  "name": "hello-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "functions:dev": "wrangler dev dev-worker.js --port 8789",
    "pages:dev": "concurrently -k \"npm run functions:dev\" \"vite\"",
    "build": "vite build",
    "deploy": "npm run build && wrangler deploy --keep-vars",
    "preview": "vite preview"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1008.0",
    "@aws-sdk/s3-request-presigner": "^3.1008.0",
    "cloudflare": "^5.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.2.0",
    "vite": "^7.3.1",
    "wrangler": "^4.0.0",
    "concurrently": "^9.0.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*"
  }
}
